# Variables de entorno - CityFlow Web
# Copia este archivo a .env y rellena los valores

# =============================================
# AZURE SQL DATABASE
# =============================================
# Servidor: yourserver.database.windows.net
DB_SERVER=yourserver.database.windows.net
DB_NAME=cityflow
DB_USER=cityflow_admin
DB_PASSWORD=YourSecurePassword123!
DB_PORT=1433

# =============================================
# JWT AUTHENTICATION
# =============================================
JWT_SECRET=cambia_esto_por_una_clave_larga_y_segura_en_produccion
JWT_EXPIRES_IN=7d

# =============================================
# SERVER
# =============================================
PORT=3000
NODE_ENV=development
